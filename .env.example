# OneClick Account Provisioning Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Docker Compose will fail without these
# ============================================

# Database
POSTGRES_DB=oneclick
POSTGRES_USER=oneclick
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Authentication Secrets
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
NEXTAUTH_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET

# N8N Webhook Authentication
N8N_WEBHOOK_API_KEY=oc_wh_Kj7mP9xR2nF5vL8qY4bD6hA3sT1wG0

# ============================================
# OPTIONAL - Defaults provided
# ============================================

# Environment
NODE_ENV=development
PORT=3001

# NextAuth
NEXTAUTH_URL=http://localhost:3000

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# N8N Webhooks
N8N_ORCHESTRATOR_WEBHOOK=https://rhei.app.n8n.cloud/webhook/provision-orchestrator
N8N_TERMINATE_WEBHOOK=https://rhei.app.n8n.cloud/webhook/terminate-orchestrator

# Azure AD / Microsoft Graph API (for license fetching)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Feature Flags
FEATURE_DRY_RUN=true
FEATURE_BULK_IMPORT=false
FEATURE_WEBHOOK_LISTENERS=false

# Scheduler
SCHEDULER_API_URL=http://localhost:8080
