# NextAuth.js
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001

# N8N Webhooks
N8N_ORCHESTRATOR_WEBHOOK=https://rhei.app.n8n.cloud/webhook/provision-orchestrator
N8N_TERMINATE_WEBHOOK=https://rhei.app.n8n.cloud/webhook/terminate-orchestrator
N8N_GROUP_CHANGE_WEBHOOK=https://rhei.app.n8n.cloud/webhook/group-change
N8N_LICENSE_CHANGE_WEBHOOK=https://rhei.app.n8n.cloud/webhook/license-change
N8N_ACCOUNT_ACTION_WEBHOOK=https://rhei.app.n8n.cloud/webhook/account-action
N8N_ROLE_CHANGE_WEBHOOK=https://rhei.app.n8n.cloud/webhook/role-change
N8N_WEBHOOK_API_KEY=your-n8n-webhook-api-key

# Azure AD / Microsoft Graph API (for license fetching and user sync)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
# If Microsoft UPNs use a different domain than managed users (e.g. user@bbtv.com vs user@rhei.com),
# set this to the Microsoft domain. The username prefix will be matched against SYNC_DOMAINS.
MICROSOFT_UPN_DOMAIN=

# Development
NODE_ENV=development

# Scheduler API (Go scheduler service — local dev only)
SCHEDULER_API_URL=http://localhost:8080

# Shared secret for Lambda → Vercel scheduler authentication
# Generate with: openssl rand -hex 32
SCHEDULER_API_KEY=generate-a-long-random-secret-here

# Google OAuth (for user login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Service Account (for Directory API - JSON string)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_ADMIN_DELEGATED_USER=mfells@broadbandtvcorp.com

# Protected accounts (comma-separated, in addition to hardcoded list)
PROTECTED_ACCOUNTS=

# GitHub (for user sync)
# Create a classic PAT at github.com/settings/tokens with read:org scope
GITHUB_PAT=your-github-pat
GITHUB_ORG_NAME=your-org-name

# Zoom (for user sync)
# Create a Server-to-Server OAuth app at marketplace.zoom.us
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Jira / Atlassian Cloud (for user sync)
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_EMAIL=api-user@your-domain.com
JIRA_API_TOKEN=your-jira-api-token

# Directory sync
# Domains to sync from Google Workspace (comma-separated)
SYNC_DOMAINS=rhei.com
# Internal API key used by Go scheduler to trigger sync (must match DIRECTORY_SYNC_API_KEY in scheduler config)
DIRECTORY_SYNC_API_KEY=

# Database (used directly by Next.js for directory users and change requests)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=oneclick
DATABASE_PASSWORD=
DATABASE_NAME=oneclick
DATABASE_SSL=false