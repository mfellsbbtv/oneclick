# NextAuth.js
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
BACKEND_URL=http://localhost:3001

# N8N Webhooks
N8N_ORCHESTRATOR_WEBHOOK=https://rhei.app.n8n.cloud/webhook/provision-orchestrator
N8N_TERMINATE_WEBHOOK=https://rhei.app.n8n.cloud/webhook/terminate-orchestrator
N8N_WEBHOOK_API_KEY=your-n8n-webhook-api-key

# Azure AD / Microsoft Graph API (for license fetching)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# Development
NODE_ENV=development

# Scheduler API (Go scheduler service)
SCHEDULER_API_URL=http://localhost:8080