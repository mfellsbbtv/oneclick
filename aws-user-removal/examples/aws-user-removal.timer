[Unit]
Description=AWS User Removal - Daily Disable Timer
Documentation=file:///opt/aws-user-removal/README.md
Requires=aws-user-removal.service

[Timer]
# Run at 2 AM UTC every day
OnCalendar=daily
OnCalendar=*-*-* 02:00:00

# Run immediately if system was off at scheduled time
Persistent=true

# Randomize start time by up to 5 minutes to avoid thundering herd
RandomizedDelaySec=5min

[Install]
WantedBy=timers.target

